# Copy this file to .env and fill in real values. .env is gitignored.

# ─── LLM (Google Gemini) ───────────────────────────────────────────
# Free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional: override the default model used by tools/summarize.py
GEMINI_MODEL=gemini-2.5-flash

# ─── Web scraping ──────────────────────────────────────────────────
# Optional custom User-Agent for tools/scrape_single_site.py
SCRAPER_USER_AGENT=

# Optional escalation scraper for blocked / JS-heavy sites (tools/firecrawl_scrape.py).
# Get a key at https://www.firecrawl.dev. Only needed if the default scraper fails.
FIRECRAWL_API_KEY=
# Optional: override the API base (defaults to https://api.firecrawl.dev)
FIRECRAWL_API_URL=

# ─── Google Workspace (Sheets / Docs / Slides / Drive) ─────────────
# Download an OAuth "Desktop app" client from Google Cloud Console and
# save it as credentials.json in the project root. token.json is created
# automatically the first time you authenticate.
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json

# ─── Slack ─────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL=#general
